{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": ".",
    "paths": {
      "@dds/ui": ["libs/dds-ui/src/public-api.ts"],
      "@dds/tokens": ["libs/dds-tokens/src/tokens.ts"],
      "@eis/profile-api": ["libs/profile-api/src/public-api.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./apps/shell/tsconfig.app.json"
    },
    {
      "path": "./apps/shell/tsconfig.spec.json"
    },
    {
      "path": "./apps/profile-mfe/tsconfig.app.json"
    },
    {
      "path": "./apps/profile-mfe/tsconfig.spec.json"
    }
  ]
}
