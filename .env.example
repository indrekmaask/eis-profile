# ---- Backend ----
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8080
# Postgres (backend datasource)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=eis_profile
POSTGRES_USER=eis
POSTGRES_PASSWORD=eis
# Registry (mock API) base URL as seen from the backend container
REGISTRY_API_BASE_URL=http://mock-api:3000
# CRM extension point — disabled (no-op) by decision
CRM_ENABLED=false

# ---- Frontend ----
# Backend base URL as seen from the browser
API_BASE_URL=http://localhost:8080
